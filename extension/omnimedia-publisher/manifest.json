{
  "manifest_version": 3,
  "name": "OmniMedia Publisher",
  "description": "Bring OmniMedia drafts into Xiaohongshu Creator Center with a safe copy-assist flow.",
  "version": "0.1.1",
  "permissions": ["tabs", "scripting", "storage", "clipboardWrite"],
  "host_permissions": [
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://creator.xiaohongshu.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*"
      ],
      "js": ["bridge.js"]
    },
    {
      "matches": ["https://creator.xiaohongshu.com/*"],
      "js": ["target_script.js"]
    }
  ]
}
