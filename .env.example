# Provider selection
OMNIMEDIA_LLM_PROVIDER=langgraph
LANGGRAPH_INNER_PROVIDER=compatible

# Compatible OpenAI-style endpoint
LLM_API_KEY=your_dashscope_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-flash
LLM_ARTIFACT_MODEL=qwen3.5-flash

# Vision model for LangGraph OCR/image understanding
# Replace with a real multimodal model supported by your provider.
LLM_VISION_MODEL=your_vision_model_here

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_ARTIFACT_MODEL=
OPENAI_VISION_MODEL=

# Shared timeout
LLM_TIMEOUT_SECONDS=60
OPENAI_TIMEOUT_SECONDS=60

# Auth
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite:///omnimedia_agent.db
