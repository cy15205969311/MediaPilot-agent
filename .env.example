# Provider selection
OMNIMEDIA_LLM_PROVIDER=langgraph
LANGGRAPH_INNER_PROVIDER=compatible

# Dedicated Qwen provider with built-in model fallback
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_PRIMARY_MODEL=qwen-max
QWEN_ARTIFACT_MODEL=qwen-max
QWEN_FALLBACK_MODELS=qwen-plus,qwen-turbo
QWEN_TIMEOUT_SECONDS=120
QWEN_RETRY_ATTEMPTS=3
QWEN_RETRY_BASE_DELAY_SECONDS=1
QWEN_ENABLE_TOOL_BINDING=false

# Compatible OpenAI-style endpoint
LLM_API_KEY=your_xiaomi_mimo_api_key
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro
LLM_ARTIFACT_MODEL=mimo-v2.5-pro

# Vision model for LangGraph OCR/image understanding
# Replace with a real multimodal model supported by your provider.
LLM_VISION_MODEL=mimo-v2-omni

# Optional Tavily search for LangGraph retrieval / business-tool market intelligence
TAVILY_API_KEY=
SEARCH_TIMEOUT_SECONDS=20

# Optional image generation backends for content artifacts
# Supported values: disabled | dashscope | openai
# You can keep both OpenAI-compatible and DashScope credentials configured.
# When IMAGE_GENERATION_BACKEND=openai and DashScope credentials are present,
# the service can gracefully fall back to DashScope if the primary gateway fails.
IMAGE_GENERATION_BACKEND=disabled
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_BASE_URL=https://dashscope.aliyuncs.com/api/v1
IMAGE_GENERATION_MODEL=qwen-image-edit-plus
IMAGE_GENERATION_COUNT=3
IMAGE_GENERATION_TIMEOUT_SECONDS=120
IMAGE_GENERATION_POLL_INTERVAL_SECONDS=2
IMAGE_GENERATION_PERSIST_RESULTS=true
IMAGE_PROMPT_API_KEY=
IMAGE_PROMPT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
IMAGE_PROMPT_MODEL=qwen-turbo
IMAGE_PROMPT_TIMEOUT_SECONDS=60
OPENAI_IMAGE_BASE_URL=https://www.onetopai.asia/v1
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_ARTIFACT_MODEL=
OPENAI_VISION_MODEL=

# Dedicated endpoint for Audio/Video Transcription (Whisper compatible)
OPENAI_TRANSCRIPTION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_TRANSCRIPTION_API_KEY=your_dashscope_transcription_api_key
OPENAI_TRANSCRIPTION_MODEL=qwen-audio-turbo

# Shared timeout
LLM_TIMEOUT_SECONDS=120
OPENAI_TIMEOUT_SECONDS=120
MEDIA_PARSER_DOWNLOAD_TIMEOUT_SECONDS=120
MEDIA_PARSER_TRANSCRIPTION_TIMEOUT_SECONDS=120
MEDIA_PARSER_DOCUMENT_MAX_CHARS=12000
MEDIA_PARSER_TRANSCRIPT_MAX_CHARS=12000

# Local frontend-backend integration
# Comma-separated origins. Leave empty to use localhost defaults.
CORS_ALLOWED_ORIGINS=

# Storage backend
# auto: prefer OSS when fully configured, otherwise fall back to local /uploads
OMNIMEDIA_STORAGE_BACKEND=auto
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET_NAME=
OSS_REGION=
OSS_PUBLIC_BASE_URL=
OSS_SIGNED_URL_EXPIRE_SECONDS=3600
OSS_SIGNED_URL_MIN_EXPIRE_SECONDS=60
OSS_SIGNED_URL_MAX_EXPIRE_SECONDS=86400
OSS_TMP_UPLOAD_EXPIRE_DAYS=3
OSS_THREAD_UPLOAD_TRANSITION_DAYS=30
OSS_THREAD_UPLOAD_TRANSITION_STORAGE_CLASS=IA
OSS_AUTO_SETUP_LIFECYCLE=false

# Auth
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
JWT_PASSWORD_RESET_EXPIRE_MINUTES=15

# Database
DATABASE_URL=sqlite:///omnimedia_agent.db
